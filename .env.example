# Base de datos PostgreSQL (Supabase / Neon / Railway)
DATABASE_URL=postgresql://user:password@host:5432/inversion_evolutiva

# Motor de inferencia DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Umbral de aviso preventivo de saldo bajo (USD) en el health_check diario.
# NO falla el check; solo emite ⚠️ para recargar antes de que el saldo llegue a
# cero y bloquee las llamadas con HTTP 402 (incidente 2026-06-15).
DEEPSEEK_LOW_BALANCE_USD=2.0

# Datos técnicos (Alpha Vantage — legado, usado puntualmente)
ALPHA_VANTAGE_API_KEY=...
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Noticias y calendario económico (Finnhub)
FINNHUB_API_KEY=...

# Configuración del ciclo evolutivo (Agente Juez)
JUDGE_RUN_TIME=23:00
JUDGE_TIMEZONE=America/Bogota
INITIAL_AGENTS_COUNT=10
AGENTS_ELIMINATE_PER_CYCLE=9   # 3 por especie × 3 especies (con MIN_AGENTS_PER_ESPECIE=2 y 5 por especie)
MIN_ROI_FOR_HALL_OF_FAME=0.05

# Horario de apertura de nuevas posiciones (zona UTC, formato HH:MM).
# 1:30 am – 11:00 pm Bogotá = 06:30 UTC – 04:00 UTC (siguiente día UTC).
# La ventana cruza la medianoche UTC; el código maneja ese caso.
TRADING_START_TIME_UTC=06:30
TRADING_CUTOFF_TIME_UTC=04:00

# Monitor de trades (modo demonio)
TRADE_MONITOR_POLL_SECONDS=60

# Realismo de mercado (Fase 0)
# Fricción round-trip (spread + slippage) en pips, descontada del P&L de cada
# operación al cerrar. 1.4 ≈ 0.8 spread retail EUR/USD + 0.6 slippage en stops.
TRADE_FRICTION_PIPS=1.4
# Piso mínimo del Stop Loss en pips. Por debajo de esto el SL muere por ruido de
# las velas de 1m. No empeora el riesgo: el sizing escala inverso a sl_pips.
MIN_SL_PIPS=10.0
# Techo del Stop Loss en pips (Sesión 22 — coherencia intradía). Un SL mayor
# produce un TP (R:R >= 1.5) inalcanzable antes del cierre EOD: el trade solo
# puede terminar en EOD o SL completo y el fitness pierde la señal. Aplica a
# todas las fuentes de SL (estructura OB/FVG y ATR).
MAX_SL_PIPS=35.0

# Parámetros de mutación genética
MUTATION_SIGMA_WEIGHTS=0.05
MUTATION_SIGMA_PERIODS=0.08
MUTATION_SIGMA_RISK=0.10

# Periodo de Gracia Operativa (Sesión 7)
# Días HÁBILES (lun-vie) que un agente recién nacido sin operaciones cerradas
# permanece inmune a la eliminación. Forex no opera fin de semana, por lo que
# sábado y domingo NO cuentan para este periodo.
GRACE_PERIOD_DAYS=2

# Forzado de diversidad genética (Sesión 7)
# Umbral del coeficiente de variación promedio del ADN de los supervivientes.
# Si CV < umbral, las sigmas de mutación se multiplican por SIGMA_BOOST_FACTOR
# para forzar exploración agresiva y evitar estancamiento por clones.
# Subir a 0.05 para criterio más estricto (más boosts), bajar para criterio relajado.
DIVERSITY_VARIANCE_THRESHOLD=0.01
SIGMA_BOOST_FACTOR=2.0

# Backtest pre-deploy (Fase 3)
# Por cada slot a cubrir, se crían N_CANDIDATE_CHILDREN y se despliega
# el que obtenga mayor fitness en el período OOS del backtest.
# Train: primeros BACKTEST_TRAIN_DAYS días (warmup). Validate: últimos BACKTEST_VALIDATE_DAYS.
BACKTEST_TRAIN_DAYS=40
BACKTEST_VALIDATE_DAYS=20
N_CANDIDATE_CHILDREN=3

# Integridad evolutiva (Fase 1)
# Operaciones cerradas mínimas antes de que un agente sea elegible para eliminación,
# reproducción o Hall of Fame. A ~2-3 trades/día ≈ 5-7 días de trading activo.
MIN_SAMPLE_TRADES=15
# Agentes mínimos por especie (tendencia/reversion/ruptura). La evolución no
# elimina un agente si hacerlo bajaría su especie por debajo de este umbral.
MIN_AGENTS_PER_ESPECIE=2

# Torneo con umbral de calidad (Fase 1 Sesión 17)
# Fitness OOS mínimo requerido (estrictamente mayor) para desplegar un hijo.
# Default 0.0 → cualquier fitness positivo pasa. Subir para mayor exigencia.
TOURNAMENT_MIN_OOS_FITNESS=0.0
# Trades OOS mínimos requeridos para desplegar un hijo del torneo.
TOURNAMENT_MIN_OOS_TRADES=5

# Tope de pérdida a la inmunidad por muestra (Fase 3 Sesión 17)
# Un agente inmune solo por muestra insuficiente pierde la inmunidad si su
# roi_total (en %) cae por debajo de este umbral negativo.
# Default 8.0 → revoca inmunidad si roi <= -8 %.
IMMUNITY_MAX_LOSS_PCT=8.0

# Muestra mínima híbrida (Fase 4 Sesión 17)
# Un agente es elegible si tiene >= MIN_SAMPLE_TRADES operaciones cerradas
# O lleva >= MIN_SAMPLE_DAYS días hábiles (lun-vie) en producción.
# La condición OR evita que especies de baja frecuencia queden inmunes indefinidamente.
MIN_SAMPLE_DAYS=7

# Recuperación de cupos vacantes (Sesión 18 / 19)
# Objetivo de agentes activos por especie; el motor SIEMPRE llena el déficit
# (3 especies × 5 = población garantizada de 15 agentes).
TARGET_AGENTS_PER_ESPECIE=5
# DEPRECADO (Sesión 19): el tope por ciclo se eliminó para garantizar los 15.
REPOPULATION_MAX_PER_CYCLE=3
# Sesión 19: rondas de reintento (torneo→HoF) por cupo antes del clon forzado.
# Acota el costo de backtests para no agotar el tiempo del cron.
REPOPULATION_MAX_ATTEMPTS_PER_SLOT=8

# Ruptura solo en régimen TENDENCIA (Fase 5 Sesión 17)
# Si true, la especie "ruptura" no abre posiciones cuando regime_estado=="RANGO".
# Aplica en trade_monitor (producción) y backtester (evaluación OOS).
# NEUTRAL sigue operando sin restricción.
RUPTURA_SOLO_TENDENCIA=true

# Validación estadística del torneo — bootstrap (Fase 2, PLAN_DE_MEJORA.md)
# legacy (default) = umbral débil actual (fitness OOS > 0 & n_trades OOS >= 5).
# bootstrap = exige que el límite inferior del IC (BOOTSTRAP_CI) de la expectancy,
# estimado por resample con reemplazo sobre los P&L OOS, sea > 0. Frena falsos
# positivos de muestra corta (ver evolution/backtester.py:bootstrap_edge_ok).
# NO cambiar a "bootstrap" sin antes revisar v_decaimiento_oos (Fase 1).
TOURNAMENT_GATE_MODE=legacy
BOOTSTRAP_ITERS=1000
BOOTSTRAP_CI=0.80
BOOTSTRAP_MIN_TRADES=8

# Walk-forward multi-fold (Fase 3, PLAN_DE_MEJORA.md)
# single (default) = split único TRAIN/VALIDATE actual, sin cambios.
# multifold = N folds deslizantes con purge gap; fitness agregado penalizado
# por varianza entre folds (más robusto a un solo régimen de mercado, pero
# ~1.68× más costoso por candidato — ver evolution/backtester.py).
# Criterio go/no-go: activar solo si v_decaimiento_oos (Fase 1) muestra
# decaimiento OOS→producción material. Hoy no hay datos suficientes aún.
BACKTEST_MODE=single
MULTIFOLD_N_FOLDS=3
MULTIFOLD_TRAIN_DAYS=30
MULTIFOLD_VALIDATE_DAYS=10
MULTIFOLD_PURGE_DAYS=1
MULTIFOLD_STEP_DAYS=10
MULTIFOLD_LAMBDA=0.5
# Presupuesto de tiempo de repoblación en segundos. SOLO se activa si
# BACKTEST_MODE=multifold: evita que el costo extra del multi-fold agote el
# timeout de judge_daily.yml (25 min) — los cupos restantes caen a cruce
# forzado en vez de rondas completas de torneo/HoF. Sin efecto en modo single.
REPOPULATION_TIME_BUDGET_SECONDS=900

# Entorno
ENVIRONMENT=development
LOG_LEVEL=INFO

GOOGLE_SHEET_ID=1AIV9NYNKXzz4HR4fNkiJTiIbRRAn3GF4oEIfnYTCYEE
GOOGLE_CREDENTIALS_JSON=google_credentials.json
