# Base de datos PostgreSQL (Supabase / Neon / Railway)
DATABASE_URL=postgresql://user:password@host:5432/inversion_evolutiva

# Motor de inferencia DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Datos técnicos (Alpha Vantage)
ALPHA_VANTAGE_API_KEY=...
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# OANDA — broker de ejecución (una sola cuenta para todos los agentes)
# Crea tu cuenta demo en: https://practice.oanda.com
OANDA_ENVIRONMENT=practice
OANDA_ACCOUNT_ID=101-001-XXXXXXXX-001
OANDA_API_TOKEN=...
OANDA_UNITS_PER_TRADE=1000

# Configuración del ciclo evolutivo (Agente Juez)
JUDGE_RUN_TIME=17:00
JUDGE_TIMEZONE=America/Bogota
INITIAL_AGENTS_COUNT=10
AGENTS_ELIMINATE_PER_CYCLE=5
MIN_ROI_FOR_HALL_OF_FAME=0.05

# Monitor de trades OANDA (modo demonio)
TRADE_MONITOR_POLL_SECONDS=60

# Parámetros de mutación genética
MUTATION_SIGMA_WEIGHTS=0.05
MUTATION_SIGMA_PERIODS=0.08
MUTATION_SIGMA_RISK=0.10

# Entorno
ENVIRONMENT=development
LOG_LEVEL=INFO

GOOGLE_SHEET_ID=1AIV9NYNKXzz4HR4fNkiJTiIbRRAn3GF4oEIfnYTCYEE
GOOGLE_CREDENTIALS_JSON=google_credentials.json
