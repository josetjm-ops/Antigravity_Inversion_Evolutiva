# Base de datos PostgreSQL (Supabase / Neon / Railway)
DATABASE_URL=postgresql://user:password@host:5432/inversion_evolutiva

# Motor de inferencia DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Datos técnicos (Alpha Vantage — legado, usado puntualmente)
ALPHA_VANTAGE_API_KEY=...
ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co/query

# Noticias y calendario económico (Finnhub)
FINNHUB_API_KEY=...

# Configuración del ciclo evolutivo (Agente Juez)
JUDGE_RUN_TIME=23:00
JUDGE_TIMEZONE=America/Bogota
INITIAL_AGENTS_COUNT=10
AGENTS_ELIMINATE_PER_CYCLE=5
MIN_ROI_FOR_HALL_OF_FAME=0.05

# Horario de apertura de nuevas posiciones (zona UTC, formato HH:MM).
# 1:30 am – 11:00 pm Bogotá = 06:30 UTC – 04:00 UTC (siguiente día UTC).
# La ventana cruza la medianoche UTC; el código maneja ese caso.
TRADING_START_TIME_UTC=06:30
TRADING_CUTOFF_TIME_UTC=04:00

# Monitor de trades (modo demonio)
TRADE_MONITOR_POLL_SECONDS=60

# Realismo de mercado (Fase 0)
# Fricción round-trip (spread + slippage) en pips, descontada del P&L de cada
# operación al cerrar. 1.4 ≈ 0.8 spread retail EUR/USD + 0.6 slippage en stops.
TRADE_FRICTION_PIPS=1.4
# Piso mínimo del Stop Loss en pips. Por debajo de esto el SL muere por ruido de
# las velas de 1m. No empeora el riesgo: el sizing escala inverso a sl_pips.
MIN_SL_PIPS=10.0

# Parámetros de mutación genética
MUTATION_SIGMA_WEIGHTS=0.05
MUTATION_SIGMA_PERIODS=0.08
MUTATION_SIGMA_RISK=0.10

# Periodo de Gracia Operativa (Sesión 7)
# Días HÁBILES (lun-vie) que un agente recién nacido sin operaciones cerradas
# permanece inmune a la eliminación. Forex no opera fin de semana, por lo que
# sábado y domingo NO cuentan para este periodo.
GRACE_PERIOD_DAYS=2

# Forzado de diversidad genética (Sesión 7)
# Umbral del coeficiente de variación promedio del ADN de los supervivientes.
# Si CV < umbral, las sigmas de mutación se multiplican por SIGMA_BOOST_FACTOR
# para forzar exploración agresiva y evitar estancamiento por clones.
# Subir a 0.05 para criterio más estricto (más boosts), bajar para criterio relajado.
DIVERSITY_VARIANCE_THRESHOLD=0.01
SIGMA_BOOST_FACTOR=2.0

# Backtest pre-deploy (Fase 3)
# Por cada slot a cubrir, se crían N_CANDIDATE_CHILDREN y se despliega
# el que obtenga mayor fitness en el período OOS del backtest.
# Train: primeros BACKTEST_TRAIN_DAYS días (warmup). Validate: últimos BACKTEST_VALIDATE_DAYS.
BACKTEST_TRAIN_DAYS=40
BACKTEST_VALIDATE_DAYS=20
N_CANDIDATE_CHILDREN=3

# Integridad evolutiva (Fase 1)
# Operaciones cerradas mínimas antes de que un agente sea elegible para eliminación,
# reproducción o Hall of Fame. A ~2-3 trades/día ≈ 5-7 días de trading activo.
MIN_SAMPLE_TRADES=15
# Agentes mínimos por especie (tendencia/reversion/ruptura). La evolución no
# elimina un agente si hacerlo bajaría su especie por debajo de este umbral.
MIN_AGENTS_PER_ESPECIE=2

# Entorno
ENVIRONMENT=development
LOG_LEVEL=INFO

GOOGLE_SHEET_ID=1AIV9NYNKXzz4HR4fNkiJTiIbRRAn3GF4oEIfnYTCYEE
GOOGLE_CREDENTIALS_JSON=google_credentials.json
